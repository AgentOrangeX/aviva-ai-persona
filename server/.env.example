# Copy to .env and adjust. Never commit your real .env.

# Server
PORT=4000
NODE_ENV=development

# Auth — generate a strong secret, e.g.  openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# CORS — the origin your client runs on (comma-separated for multiple)
CLIENT_ORIGIN=http://localhost:5173

# First admin (seeded on boot if it does not already exist)
ADMIN_EMAIL=admin@aviva.example
ADMIN_PASSWORD=change-this-strong-password
ADMIN_NAME=Aviva Admin

# Password hashing cost
BCRYPT_ROUNDS=12

# Optional: custom database location
# DATABASE_PATH=./data/app.db
