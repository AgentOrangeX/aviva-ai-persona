# Copy to .env to override. In local development you normally DON'T need this —
# Vite proxies /api to the backend automatically (see vite.config.js).
#
# Set this ONLY for a production build where the client and API are on
# different origins (e.g. two Railway services). Point it at the API's
# public URL, with NO trailing /api and no trailing slash:
#
# VITE_API_URL=https://aviva-persona-api.up.railway.app
